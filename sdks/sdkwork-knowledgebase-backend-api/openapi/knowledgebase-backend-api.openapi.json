  "components": {
    "schemas": {
      "CreateKnowledgeSpaceRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "KnowledgeSpace": {
        "type": "object",
        "required": [
          "id",
          "uuid",
          "name",
          "status",
          "llmWikiInitialized"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64"
          },
          "uuid": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/KnowledgeSpaceStatus"
          },
          "llmWikiInitialized": {
            "type": "boolean"
          }
        }
      },
      "KnowledgeSpaceStatus": {
        "type": "string",
        "enum": [
          "active",
          "archived",
          "deleted"
        ]
      },
      "KnowledgeIngestRequest": {
        "type": "object",
        "required": [
          "spaceId",
          "title",
          "payloadMarkdown",
          "idempotencyKey"
        ],
        "properties": {
          "spaceId": {
            "type": "integer",
            "format": "uint64"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "payloadMarkdown": {
            "type": "string",
            "minLength": 1
          },
          "idempotencyKey": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        }
      },
      "IngestionJob": {
        "type": "object",
        "required": [
          "id",
          "spaceId",
          "sourceType",
          "idempotencyKey",
          "state"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64"
          },
          "spaceId": {
            "type": "integer",
            "format": "uint64"
          },
          "sourceType": {
            "type": "string"
          },
          "idempotencyKey": {
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/IngestionJobState"
          },
          "errorMessage": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "IngestionJobState": {
        "type": "string",
        "enum": [
          "queued",
          "running",
          "succeeded",
          "failed",
          "cancelled"
        ]
      },
      "KnowledgeDriveImportRequest": {
        "type": "object",
        "required": [
          "spaceId",
          "title",
          "driveBucket",
          "driveObjectKey",
          "idempotencyKey"
        ],
        "properties": {
          "spaceId": {
            "type": "integer",
            "format": "uint64"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "driveBucket": {
            "type": "string",
            "minLength": 1
          },
          "driveObjectKey": {
            "type": "string",
            "minLength": 1
          },
          "idempotencyKey": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "language": {
            "type": [
              "string",
              "null"
            ]
          },
          "driveSpaceId": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 128
          },
          "driveNodeId": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 128
          }
        }
      },
      "KnowledgeSource": {
        "type": "object",
        "required": [
          "id",
          "spaceId",
          "sourceType"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64"
          },
          "spaceId": {
            "type": "integer",
            "format": "uint64"
          },
          "sourceType": {
            "$ref": "#/components/schemas/KnowledgeSourceType"
          },
          "provider": {
            "type": [
              "string",
              "null"
            ]
          },
          "driveBucket": {
            "type": [
              "string",
              "null"
            ]
          },
          "drivePrefix": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "KnowledgeSourceType": {
        "type": "string",
        "enum": [
          "upload",
          "drive_object",
          "drive_folder",
          "url",
          "connector",
          "api"
        ]
      },
      "KnowledgeDocument": {
        "type": "object",
        "required": [
          "id",
          "spaceId",
          "collectionId",
          "title",
          "visibility",
          "contentState",
          "indexState"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64"
          },
          "spaceId": {
            "type": "integer",
            "format": "uint64"
          },
          "collectionId": {
            "type": "integer",
            "format": "uint64"
          },
          "sourceId": {
            "type": [
              "integer",
              "null"
            ],
            "format": "uint64"
          },
          "title": {
            "type": "string"
          },
          "mimeType": {
            "type": [
              "string",
              "null"
            ]
          },
          "language": {
            "type": [
              "string",
              "null"
            ]
          },
          "currentVersionId": {
            "type": [
              "integer",
              "null"
            ],
            "format": "uint64"
          },
          "visibility": {
            "$ref": "#/components/schemas/KnowledgeDocumentVisibility"
          },
          "contentState": {
            "$ref": "#/components/schemas/KnowledgeDocumentState"
          },
          "indexState": {
            "$ref": "#/components/schemas/KnowledgeDocumentVersionState"
          }
        }
      },
      "KnowledgeDocumentVersion": {
        "type": "object",
        "required": [
