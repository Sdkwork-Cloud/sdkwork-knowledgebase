{
  "name": "@sdkwork/knowledgebase-internal-sdk",
  "version": "0.1.0",
  "description": "Private composed SDKWork Knowledgebase Internal API client.",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "generated/server-openapi/dist",
    "generated/server-openapi/src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@sdkwork/sdk-common": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "keywords": [
    "sdkwork",
    "knowledgebase",
    "internal-sdk"
  ]
}
