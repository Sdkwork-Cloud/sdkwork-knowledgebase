{
  "name": "sdkwork-knowledgebase-workspace",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "dependencies": {
    "@sdkwork/app-topology": "file:../sdkwork-app-topology"
  },
  "scripts": {
    "dev": "pnpm dev:browser",
    "dev:browser": "pnpm dev:browser:postgres:unified-process:standalone",
    "dev:browser:postgres": "pnpm dev:browser:postgres:unified-process:standalone",
    "dev:browser:postgres:unified-process:standalone": "node scripts/knowledgebase-dev.mjs --target browser --deployment-profile standalone --service-layout unified-process --database postgres --dev-env-file .env.postgres",
    "dev:browser:sqlite": "node scripts/knowledgebase-dev.mjs --target browser --deployment-profile standalone --service-layout unified-process --database sqlite",
    "dev:browser:postgres:split-services:cloud": "node scripts/knowledgebase-dev.mjs --target browser --deployment-profile cloud --service-layout split-services --database postgres --dev-env-file .env.postgres",
    "dev:desktop": "pnpm dev:desktop:postgres:unified-process:standalone",
    "dev:desktop:postgres": "pnpm dev:desktop:postgres:unified-process:standalone",
    "dev:desktop:postgres:unified-process:standalone": "node scripts/knowledgebase-dev.mjs --target desktop --deployment-profile standalone --service-layout unified-process --database postgres --dev-env-file .env.postgres",
    "dev:desktop:sqlite": "node scripts/knowledgebase-dev.mjs --target desktop --deployment-profile standalone --service-layout unified-process --database sqlite",
    "build": "pnpm --dir apps/sdkwork-knowledgebase-pc run build",
    "build:desktop": "pnpm --dir apps/sdkwork-knowledgebase-pc run build:desktop",
    "build:server": "cargo build --release -p sdkwork-knowledgebase-standalone-gateway",
    "test": "pnpm topology:validate && pnpm test:topology && pnpm test:frontend && pnpm test:rust && pnpm test:smoke && pnpm test:launch-readiness && pnpm test:e2e && pnpm test:observability && pnpm test:security && pnpm db:validate",
    "test:rust": "cargo test --workspace",
    "test:security": "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-security.test.mjs",
    "test:observability": "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-observability.test.mjs",
    "test:smoke": "node --test --experimental-test-isolation=none scripts/smoke-knowledgebase-api.test.mjs",
    "test:launch-readiness": "node --test --experimental-test-isolation=none scripts/verify-launch-runbook.test.mjs && node --test --experimental-test-isolation=none scripts/smoke-knowledgebase-open-api.test.mjs && node --test --experimental-test-isolation=none scripts/smoke-knowledgebase-admin-ingest.test.mjs",
    "test:phase2-readiness": "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-phase2-readiness.test.mjs",
    "test:e2e": "node --test --experimental-test-isolation=none scripts/e2e-knowledgebase-pc-bootstrap.test.mjs && node --test --experimental-test-isolation=none scripts/e2e-knowledgebase-pc-browser.test.mjs",
    "test:e2e:playwright": "pnpm --dir apps/sdkwork-knowledgebase-pc run test:e2e",
    "test:topology": "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-topology.test.mjs",
    "test:frontend": "pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-commons test && pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-core test && pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-search test && pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-knowledgebase test && pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-shell test",
    "check": "pnpm check:architecture-alignment && pnpm check:pc-app-hygiene && pnpm check:utils-integration && pnpm check:pnpm-script-standard && pnpm check:agent-workflow-standard && pnpm check:okf-standard && pnpm check:external-engine-catalog && pnpm check:knowledge-engine-spi",
    "check:utils-integration": "node tools/check_utils_integration_standard.mjs",
    "check:okf-standard": "node tools/check_okf_knowledge_bundle_standard.mjs",
    "check:external-engine-catalog": "node tools/check_external_knowledge_engine_catalog.mjs",
    "check:knowledge-engine-spi": "node tools/check_knowledge_engine_spi_standard.mjs",
    "check:architecture-alignment": "node tools/check_sdkwork_knowledgebase_architecture_alignment.mjs",
    "check:pc-app-hygiene": "node tools/check_pc_app_hygiene.mjs",
    "check:pnpm-script-standard": "node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root . --product-prefix knowledgebase,kb",
    "check:agent-workflow-standard": "node ../sdkwork-specs/tools/check-agent-workflow-standard.mjs --root .",
    "verify": "powershell -ExecutionPolicy Bypass -File tools/verify_phase1.ps1 && pnpm check && pnpm test:security && pnpm test:observability && pnpm test:launch-readiness && pnpm test:phase2-readiness && pnpm gateway:validate:cloud",
    "clean": "cargo clean && node -e \"const fs=require('node:fs'); for (const dir of ['artifacts','target']) { if (fs.existsSync(dir)) fs.rmSync(dir,{recursive:true,force:true}); }\"",
    "typecheck": "pnpm --dir apps/sdkwork-knowledgebase-pc run lint",
    "lint": "pnpm --dir apps/sdkwork-knowledgebase-pc run lint",
    "lint:strict:pc-core": "pnpm --dir apps/sdkwork-knowledgebase-pc run lint:strict:core",
    "api:materialize": "node tools/apply-knowledgebase-openapi-auth-mode.mjs && node tools/apply-knowledgebase-openapi-permissions.mjs && node tools/materialize-apis-authority.mjs",
    "api:materialize:check": "node tools/apply-knowledgebase-openapi-auth-mode.mjs --check && node tools/apply-knowledgebase-openapi-permissions.mjs --check && node tools/materialize-apis-authority.mjs --check",
    "api:auth-mode": "node tools/apply-knowledgebase-openapi-auth-mode.mjs",
    "api:auth-mode:check": "node tools/apply-knowledgebase-openapi-auth-mode.mjs --check",
    "api:check": "node tools/materialize-apis-authority.mjs --check",
    "sdk:generate:check": "node sdks/standardize-knowledgebase-sdk-family.mjs --check",
    "sdk:check": "node sdks/test/verify-sdk-ownership-boundaries.test.mjs",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_knowledgebase_legacy_baseline.sql --module-id knowledgebase --owner knowledgebase-platform --prefixes kb_ --engines postgres",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "gateway:package:cloud": "node ../sdkwork-app-topology/scripts/gateway-cloud-bundle.mjs bundle --root .",
    "gateway:validate:cloud": "node ../sdkwork-app-topology/scripts/gateway-cloud-bundle.mjs validate --root .",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs",
    "db:postgres:init": "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode init --config .env.postgres --app-root .",
    "db:postgres:plan": "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode plan --config .env.postgres --app-root . --dry-run"
  }
}
