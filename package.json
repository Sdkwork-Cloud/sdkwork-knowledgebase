{
    "name":  "sdkwork-knowledgebase-workspace",
    "private":  true,
    "license": "AGPL-3.0-or-later",
    "type":  "module",
    "packageManager":  "pnpm@10.33.0",
    "dependencies":  {
                         "@sdkwork/app-topology":  "workspace:*"
                     },
    "scripts":  {
                    "stop":  "pnpm exec sdkwork-app stop",
                    "dev":  "pnpm dev:standalone",
                    "dev:browser":  "pnpm dev:browser:postgres:standalone",
                    "dev:browser:postgres":  "pnpm exec sdkwork-app dev --runtime-target browser --deployment-profile standalone",
                    "dev:browser:postgres:standalone":  "pnpm exec sdkwork-app dev --runtime-target browser --deployment-profile standalone",
                    "dev:browser:sqlite":  "node scripts/knowledgebase-dev.mjs --target browser --deployment-profile standalone --database sqlite",
                    "dev:desktop":  "pnpm dev:desktop:postgres:standalone",
                    "dev:desktop:postgres":  "pnpm exec sdkwork-app dev --runtime-target desktop --deployment-profile standalone",
                    "dev:desktop:postgres:standalone":  "pnpm exec sdkwork-app dev --runtime-target desktop --deployment-profile standalone",
                    "dev:desktop:sqlite":  "node scripts/knowledgebase-dev.mjs --target desktop --deployment-profile standalone --database sqlite",
                    "build":  "pnpm exec sdkwork-app build",
                    "build:desktop":  "pnpm --dir apps/sdkwork-knowledgebase-pc run build:desktop",
                    "build:server":  "cargo build --release -p sdkwork-api-knowledgebase-standalone-gateway",
                    "test":  "pnpm exec sdkwork-app test",
                    "test:rust":  "cargo test --workspace -- --quiet",
                    "test:provider-certification":  "node tools/run_provider_certification.mjs --execute",
                    "test:security":  "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-security.test.mjs \u0026\u0026 node --test --experimental-test-isolation=none scripts/verify-knowledgebase-permission-bootstrap.test.mjs",
                    "test:observability":  "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-observability.test.mjs",
                    "test:smoke":  "node --test --experimental-test-isolation=none scripts/smoke-knowledgebase-api.test.mjs",
                    "test:launch-readiness":  "node --test --experimental-test-isolation=none scripts/verify-launch-runbook.test.mjs \u0026\u0026 node --test --experimental-test-isolation=none scripts/smoke-knowledgebase-open-api.test.mjs \u0026\u0026 node --test --experimental-test-isolation=none scripts/smoke-knowledgebase-admin-ingest.test.mjs",
                    "test:phase2-readiness":  "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-phase2-readiness.test.mjs \u0026\u0026 node --test --experimental-test-isolation=none scripts/verify-knowledgebase-tenant-quota.test.mjs \u0026\u0026 pnpm test:multi-tenant-isolation \u0026\u0026 pnpm test:billing-metering",
                    "test:multi-tenant-isolation":  "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-multi-tenant-isolation.test.mjs",
                    "test:tenant-quota":  "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-tenant-quota.test.mjs",
                    "test:billing-metering":  "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-billing-metering.test.mjs",
                    "test:e2e":  "node --test --experimental-test-isolation=none scripts/e2e-knowledgebase-pc-bootstrap.test.mjs \u0026\u0026 node --test --experimental-test-isolation=none scripts/e2e-knowledgebase-pc-browser.test.mjs",
                    "test:e2e:playwright":  "pnpm --dir apps/sdkwork-knowledgebase-pc run test:e2e",
                    "test:topology":  "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-topology.test.mjs",
                    "test:frontend":  "pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-commons test \u0026\u0026 pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-core test \u0026\u0026 pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-search test \u0026\u0026 pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-knowledgebase test \u0026\u0026 pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-shell test \u0026\u0026 pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-admin-core test \u0026\u0026 pnpm --dir apps/sdkwork-knowledgebase-pc/packages/sdkwork-knowledgebase-pc-admin-provider test",
                    "check":  "pnpm exec sdkwork-app check",
                    "check:app-composition":  "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
                    "check:utils-integration":  "node tools/check_utils_integration_standard.mjs",
                    "check:okf-standard":  "node tools/check_okf_knowledge_bundle_standard.mjs",
                    "check:external-engine-catalog":  "node tools/check_external_knowledge_engine_catalog.mjs",
                    "check:provider-certification":  "node --test tools/provider_certification.test.mjs \u0026\u0026 node tools/run_provider_certification.mjs",
                    "check:knowledge-engine-spi":  "node --test tools/evaluate_knowledge_engine_retrieval.test.mjs tools/quality_evaluation_evidence.test.mjs \u0026\u0026 node tools/check_knowledge_engine_spi_standard.mjs",
                    "check:verification-pipeline":  "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-verification-pipeline.test.mjs",
                    "check:architecture-alignment":  "node tools/check_sdkwork_knowledgebase_architecture_alignment.mjs",
                    "check:pc-app-hygiene":  "node tools/check_pc_app_hygiene.mjs",
                    "check:source-hygiene":  "node --test --experimental-test-isolation=none scripts/verify-knowledgebase-source-hygiene.test.mjs",
                    "check:pnpm-script-standard":  "node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root . --product-prefix knowledgebase,kb",
                    "check:agent-workflow-standard":  "node ../sdkwork-specs/tools/check-agent-workflow-standard.mjs --root .",
                    "verify":  "pnpm exec sdkwork-app verify",
                    "clean":  "pnpm exec sdkwork-app clean",
                    "typecheck":  "pnpm --dir apps/sdkwork-knowledgebase-pc run lint",
                    "lint":  "pnpm --dir apps/sdkwork-knowledgebase-pc run lint",
                    "lint:strict:pc-core":  "pnpm --dir apps/sdkwork-knowledgebase-pc run lint:strict:core",
                    "api:materialize":  "node tools/sync-route-manifest-json.mjs \u0026\u0026 node tools/patch-commerce-app-openapi.mjs \u0026\u0026 node tools/align-knowledgebase-openapi-standard.mjs \u0026\u0026 node scripts/align-app-api-int64-string-fields.mjs \u0026\u0026 node tools/apply-knowledgebase-openapi-auth-mode.mjs \u0026\u0026 node tools/apply-knowledgebase-openapi-permissions.mjs \u0026\u0026 node sdks/standardize-knowledgebase-sdk-family.mjs \u0026\u0026 node tools/materialize-apis-authority.mjs",
                    "api:align-envelope":  "node tools/align-knowledgebase-openapi-standard.mjs \u0026\u0026 node tools/patch-commerce-app-openapi.mjs",
                    "api:materialize:check":  "node tools/sync-route-manifest-json.mjs --check \u0026\u0026 node tools/patch-commerce-app-openapi.mjs --check \u0026\u0026 node tools/align-knowledgebase-openapi-standard.mjs --check \u0026\u0026 node scripts/align-app-api-int64-string-fields.mjs --check \u0026\u0026 node tools/apply-knowledgebase-openapi-auth-mode.mjs --check \u0026\u0026 node tools/apply-knowledgebase-openapi-permissions.mjs --check \u0026\u0026 node sdks/standardize-knowledgebase-sdk-family.mjs --check \u0026\u0026 node tools/materialize-apis-authority.mjs --check",
                    "api:auth-mode":  "node tools/apply-knowledgebase-openapi-auth-mode.mjs",
                    "api:auth-mode:check":  "node tools/apply-knowledgebase-openapi-auth-mode.mjs --check",
                    "api:check":  "node tools/materialize-apis-authority.mjs --check",
                    "sdk:generate:check":  "node sdks/standardize-knowledgebase-sdk-family.mjs --check",
                    "sdk:check":  "node sdks/test/verify-sdk-ownership-boundaries.test.mjs",
                    "db:materialize:contract":  "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_knowledgebase_baseline.sql --module-id knowledgebase --owner knowledgebase-platform --prefixes kb_,web_ --engines postgres,sqlite",
                    "db:validate":  "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
                    "topology:validate":  "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
                    "topology:plan":  "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
                    "db:plan":  "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
                    "db:init":  "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
                    "db:migrate":  "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
                    "db:seed":  "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
                    "db:status":  "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
                    "db:drift":  "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
                    "db:drift:check":  "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
                    "db:bootstrap":  "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
                    "test:contract:database":  "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
                    "api:assembly:materialize":  "node ../sdkwork-specs/tools/materialize-api-assembly.mjs --root .",
                    "api:assembly:validate":  "node ../sdkwork-specs/tools/validate-api-assembly.mjs --root .",
                    "db:postgres:init":  "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode init --config .env.postgres --app-root .",
                    "db:postgres:plan":  "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode plan --config .env.postgres --app-root . --dry-run",
                    "_sdkwork:build":  "pnpm --dir apps/sdkwork-knowledgebase-pc run build",
                    "_sdkwork:test":  "pnpm topology:validate \u0026\u0026 pnpm test:topology \u0026\u0026 pnpm test:frontend \u0026\u0026 pnpm test:rust \u0026\u0026 pnpm test:smoke \u0026\u0026 pnpm test:launch-readiness \u0026\u0026 pnpm test:e2e \u0026\u0026 pnpm test:observability \u0026\u0026 pnpm test:security \u0026\u0026 pnpm db:validate",
                    "_sdkwork:check":  "pnpm api:materialize:check \u0026\u0026 pnpm check:architecture-alignment \u0026\u0026 pnpm check:app-composition \u0026\u0026 pnpm check:pc-app-hygiene \u0026\u0026 pnpm check:source-hygiene \u0026\u0026 pnpm check:utils-integration \u0026\u0026 pnpm check:pnpm-script-standard \u0026\u0026 pnpm check:agent-workflow-standard \u0026\u0026 pnpm check:okf-standard \u0026\u0026 pnpm check:external-engine-catalog \u0026\u0026 pnpm check:provider-certification \u0026\u0026 pnpm check:knowledge-engine-spi \u0026\u0026 pnpm check:verification-pipeline",
                    "_sdkwork:verify":  "powershell -ExecutionPolicy Bypass -File tools/verify_phase1.ps1 \u0026\u0026 pnpm check \u0026\u0026 pnpm test:security \u0026\u0026 pnpm test:observability \u0026\u0026 pnpm test:launch-readiness \u0026\u0026 pnpm test:phase2-readiness \u0026\u0026 pnpm gateway:validate:cloud \u0026\u0026 pnpm run check:app-composition",
                    "_sdkwork:clean":  "cargo clean \u0026\u0026 node -e \"const fs=require(\u0027node:fs\u0027); for (const dir of [\u0027artifacts\u0027,\u0027target\u0027]) { if (fs.existsSync(dir)) fs.rmSync(dir,{recursive:true,force:true}); }\"",
                    "dev:standalone":  "pnpm exec sdkwork-app dev --deployment-profile standalone",
                    "dev:cloud":  "pnpm exec sdkwork-app dev --deployment-profile cloud",
                    "dev:browser:cloud":  "pnpm exec sdkwork-app dev --runtime-target browser --deployment-profile cloud"
                },
    "exports":  {
                    ".":  {
                              "types":  "./src/index.ts",
                              "import":  "./src/index.ts",
                              "default":  "./src/index.ts"
                          }
                }
}
