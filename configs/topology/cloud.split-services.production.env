# Knowledgebase topology profile: cloud + split-services + production

SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=cloud
SDKWORK_KNOWLEDGEBASE_SERVICE_LAYOUT=split-services
SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=production
SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=prod
SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=container
SDKWORK_KNOWLEDGEBASE_PROFILE_ID=cloud.split-services.production

SDKWORK_KNOWLEDGEBASE_DATABASE_ENGINE=postgresql
SDKWORK_KNOWLEDGEBASE_DATABASE_HOST=db.example.com
SDKWORK_KNOWLEDGEBASE_DATABASE_PORT=5432
SDKWORK_KNOWLEDGEBASE_DATABASE_NAME=sdkwork_knowledgebase_prod
SDKWORK_KNOWLEDGEBASE_DATABASE_SCHEMA=public
SDKWORK_KNOWLEDGEBASE_DATABASE_USERNAME=sdkworkprod
SDKWORK_KNOWLEDGEBASE_DATABASE_PASSWORD_FILE=/run/secrets/sdkwork-knowledgebase-database-password
SDKWORK_KNOWLEDGEBASE_DATABASE_SSL_MODE=require
SDKWORK_KNOWLEDGEBASE_DATABASE_MAX_CONNECTIONS=32

SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=https://knowledgebase.sdkwork.com/app/v3/api
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=https://knowledgebase-admin.sdkwork.com/backend/v3/api
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=https://knowledge.sdkwork.com/knowledge/v3/api

SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_AUTOSTART=false
SDKWORK_API_GATEWAY_CONFIG=configs/sdkwork-api-gateway.knowledgebase.production.toml

VITE_SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=production
VITE_SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=prod
VITE_SDKWORK_KNOWLEDGEBASE_BUILD_MODE=production
VITE_SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=browser
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=https://knowledgebase.sdkwork.com/app/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=https://knowledgebase-admin.sdkwork.com/backend/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=https://knowledge.sdkwork.com/knowledge/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
