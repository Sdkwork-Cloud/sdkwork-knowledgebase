# Knowledgebase topology profile: self-hosted + split-services + development

SDKWORK_KNOWLEDGEBASE_HOSTING=self-hosted
SDKWORK_KNOWLEDGEBASE_SERVICE_LAYOUT=split-services
SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=development
SDKWORK_KNOWLEDGEBASE_PROFILE_ID=self-hosted.split-services.development

SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_BIND=127.0.0.1:18082
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:18082
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_BIND=127.0.0.1:18083
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=http://127.0.0.1:18083

SDKWORK_KNOWLEDGEBASE_DATABASE_URL=sqlite://./.sdkwork/knowledgebase/product.db?mode=rwc
SDKWORK_KNOWLEDGEBASE_TENANT_ID=20001
SDKWORK_KNOWLEDGEBASE_DRIVE_STORAGE_ROOT=./.sdkwork/knowledgebase/drive-storage

SDKWORK_API_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_KNOWLEDGEBASE_HOSTING=self-hosted
VITE_SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=development
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18081
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:18082
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=http://127.0.0.1:18083
VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_APPBASE_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_SDKWORK_IAM_APP_API_BASE_URL=http://127.0.0.1:3900
