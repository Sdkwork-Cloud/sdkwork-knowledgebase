# Knowledgebase topology profile: standalone + unified-process + development

SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=standalone
SDKWORK_KNOWLEDGEBASE_SERVICE_LAYOUT=unified-process
SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=development
SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=dev
SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=server
SDKWORK_KNOWLEDGEBASE_PROFILE_ID=standalone.unified-process.development

SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_BIND=127.0.0.1:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_BIND=127.0.0.1:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=http://127.0.0.1:18081

SDKWORK_KNOWLEDGEBASE_DATABASE_ENGINE=postgresql
SDKWORK_KNOWLEDGEBASE_DATABASE_HOST=127.0.0.1
SDKWORK_KNOWLEDGEBASE_DATABASE_PORT=5432
SDKWORK_KNOWLEDGEBASE_DATABASE_NAME=sdkwork_knowledgebase_dev
SDKWORK_KNOWLEDGEBASE_DATABASE_SCHEMA=public
SDKWORK_KNOWLEDGEBASE_DATABASE_USERNAME=sdkworkdev
SDKWORK_KNOWLEDGEBASE_DATABASE_PASSWORD=sdkwork_dev_password
SDKWORK_KNOWLEDGEBASE_DATABASE_SSL_MODE=disable
SDKWORK_KNOWLEDGEBASE_DATABASE_MAX_CONNECTIONS=10
SDKWORK_KNOWLEDGEBASE_DATABASE_URL=postgresql://sdkworkdev:sdkwork_dev_password@127.0.0.1:5432/sdkwork_knowledgebase_dev?sslmode=disable

SDKWORK_KNOWLEDGEBASE_TENANT_ID=20001
SDKWORK_KNOWLEDGEBASE_ORGANIZATION_ID=7001
SDKWORK_KNOWLEDGEBASE_ACTOR_ID=42
SDKWORK_KNOWLEDGEBASE_OPERATOR_ID=99
SDKWORK_KNOWLEDGEBASE_DEV_AUTH_BYPASS=true
SDKWORK_KNOWLEDGEBASE_DRIVE_STORAGE_ROOT=./.sdkwork/runtime/knowledgebase/drive-storage

# Local IAM bootstrap for development only.
SDKWORK_IAM_LOCAL_APP_ID=sdkwork-knowledgebase-pc
SDKWORK_IAM_LOCAL_TENANT_ID=tenant_knowledgebase_dev
SDKWORK_IAM_LOCAL_ORGANIZATION_ID=org_knowledgebase_dev
SDKWORK_IAM_LOCAL_ORGANIZATION_NAME=Knowledgebase Dev Organization
SDKWORK_IAM_LOCAL_DEPARTMENT_ID=dept_knowledgebase_dev
SDKWORK_IAM_LOCAL_DEPARTMENT_NAME=Knowledgebase Dev Department
SDKWORK_IAM_LOCAL_POSITION_ID=pos_knowledgebase_dev
SDKWORK_IAM_LOCAL_POSITION_NAME=Knowledgebase Dev Position
SDKWORK_IAM_LOCAL_BOOTSTRAP_EMAIL=admin@sdkwork.test
SDKWORK_IAM_LOCAL_BOOTSTRAP_PASSWORD=AdminPass#2026
SDKWORK_IAM_TENANT_SIGNING_MASTER_SECRET=sdkwork-knowledgebase-dev-signing-secret

SDKWORK_API_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=standalone
VITE_SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=development
VITE_SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=dev
VITE_SDKWORK_KNOWLEDGEBASE_BUILD_MODE=development
VITE_SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=browser
VITE_SDKWORK_KNOWLEDGEBASE_DEV_SAME_ORIGIN_API=true
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18081
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:18081
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=http://127.0.0.1:18081
VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_APPBASE_APP_API_BASE_URL=http://127.0.0.1:18081
VITE_SDKWORK_IAM_APP_API_BASE_URL=http://127.0.0.1:18081
