# Knowledgebase topology profile: cloud + split-services + development

SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=cloud
SDKWORK_KNOWLEDGEBASE_SERVICE_LAYOUT=split-services
SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=development
SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=dev
SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=container
SDKWORK_KNOWLEDGEBASE_PROFILE_ID=cloud.split-services.development

SDKWORK_KNOWLEDGEBASE_DATABASE_ENGINE=postgresql
SDKWORK_KNOWLEDGEBASE_DATABASE_HOST=127.0.0.1
SDKWORK_KNOWLEDGEBASE_DATABASE_PORT=5432
SDKWORK_KNOWLEDGEBASE_DATABASE_NAME=sdkwork_knowledgebase_dev
SDKWORK_KNOWLEDGEBASE_DATABASE_SCHEMA=public
SDKWORK_KNOWLEDGEBASE_DATABASE_USERNAME=sdkworkdev
SDKWORK_KNOWLEDGEBASE_DATABASE_PASSWORD=sdkwork_dev_password
SDKWORK_KNOWLEDGEBASE_DATABASE_SSL_MODE=disable
SDKWORK_KNOWLEDGEBASE_DATABASE_MAX_CONNECTIONS=10
SDKWORK_KNOWLEDGEBASE_DATABASE_URL=postgresql://sdkworkdev:sdkwork_dev_password@127.0.0.1:5432/sdkwork_knowledgebase_dev?sslmode=disable

SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=https://api-dev.sdkwork.com/app/v3/api
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=https://api-dev.sdkwork.com/backend/v3/api
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=https://api-dev.sdkwork.com/knowledge/v3/api

SDKWORK_API_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_API_GATEWAY_CONFIG=configs/sdkwork-api-gateway.knowledgebase.development.toml
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_AUTOSTART=true

VITE_SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=development
VITE_SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=dev
VITE_SDKWORK_KNOWLEDGEBASE_BUILD_MODE=development
VITE_SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=browser
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=https://api-dev.sdkwork.com/app/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=https://api-dev.sdkwork.com/backend/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=https://api-dev.sdkwork.com/knowledge/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_APPBASE_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_SDKWORK_IAM_APP_API_BASE_URL=http://127.0.0.1:3900
