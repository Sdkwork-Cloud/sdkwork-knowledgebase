# Knowledgebase topology profile: self-hosted + unified-process + production

SDKWORK_KNOWLEDGEBASE_HOSTING=self-hosted
SDKWORK_KNOWLEDGEBASE_SERVICE_LAYOUT=unified-process
SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=production
SDKWORK_KNOWLEDGEBASE_PROFILE_ID=self-hosted.unified-process.production

SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_BIND=0.0.0.0:18082
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:18082
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_BIND=0.0.0.0:18083
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=http://127.0.0.1:18083

SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_KNOWLEDGEBASE_HOSTING=self-hosted
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18081
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:18082
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=http://127.0.0.1:18083
VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
