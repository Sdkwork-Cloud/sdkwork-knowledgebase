# Knowledgebase topology profile: cloud + unified-process + development

SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=cloud
SDKWORK_KNOWLEDGEBASE_SERVICE_LAYOUT=unified-process
SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=development
SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=dev
SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=container
SDKWORK_KNOWLEDGEBASE_PROFILE_ID=cloud.unified-process.development

SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_dev
# Load from .env.postgres (copy from .env.postgres.example). Do not commit secrets here.
# SDKWORK_CLAW_DATABASE_PASSWORD=
SDKWORK_CLAW_DATABASE_SSL_MODE=disable
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=10

# Unified process: all API surfaces share one base URL
SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=https://api-dev.sdkwork.com
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=https://api-dev.sdkwork.com
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=https://api-dev.sdkwork.com

SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.knowledgebase.development.toml
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_AUTOSTART=true

VITE_SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=development
VITE_SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=dev
VITE_SDKWORK_KNOWLEDGEBASE_BUILD_MODE=development
VITE_SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=browser
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=https://api-dev.sdkwork.com
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=https://api-dev.sdkwork.com
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=https://api-dev.sdkwork.com
VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_APPBASE_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_SDKWORK_IAM_APP_API_BASE_URL=http://127.0.0.1:3900
