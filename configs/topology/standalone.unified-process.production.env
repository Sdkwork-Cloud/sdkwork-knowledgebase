# Knowledgebase topology profile: standalone + unified-process + production

SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=standalone
SDKWORK_KNOWLEDGEBASE_SERVICE_LAYOUT=unified-process
SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=production
SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=prod
SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=server
SDKWORK_KNOWLEDGEBASE_PROFILE_ID=standalone.unified-process.production

SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_BIND=0.0.0.0:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_BIND=0.0.0.0:18081
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=http://127.0.0.1:18081

SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=db.example.com
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork
SDKWORK_CLAW_DATABASE_SCHEMA=public
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork
SDKWORK_CLAW_DATABASE_PASSWORD_FILE=/etc/sdkwork/database.secret
SDKWORK_CLAW_DATABASE_SSL_MODE=require
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=16

SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=standalone
VITE_SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=production
VITE_SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=prod
VITE_SDKWORK_KNOWLEDGEBASE_BUILD_MODE=production
VITE_SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=desktop
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18081
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:18081
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=http://127.0.0.1:18081
VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
