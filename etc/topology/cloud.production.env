
SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=cloud
SDKWORK_DRIVE_DOMAIN_OUTBOX_EMBEDDED_DISPATCH=false
SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=production
SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=prod
SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=container
SDKWORK_KNOWLEDGEBASE_PROFILE_ID=cloud.production

# Runtime tenant binding (one tenant per API/worker process)
SDKWORK_KNOWLEDGEBASE_TENANT_ID=1
# SDKWORK_KNOWLEDGEBASE_ORGANIZATION_ID=0
SDKWORK_KNOWLEDGEBASE_DRIVE_INTERNAL_API_BASE_URL=https://drive-internal.sdkwork.com
SDKWORK_KNOWLEDGEBASE_DRIVE_INTERNAL_API_INGRESS_TOKEN_FILE=/run/secrets/sdkwork/drive-internal-api-ingress-token
SDKWORK_KNOWLEDGEBASE_DRIVE_EVENT_CALLBACK_URL=https://knowledgebase.sdkwork.com/internal/v3/api/knowledgebase/drive_events
SDKWORK_KNOWLEDGEBASE_DRIVE_EVENT_SIGNING_SECRET_FILE=/run/secrets/sdkwork/drive-event-signing/current
# Mount only during a controlled signing-secret rotation and remove after the overlap window.
# SDKWORK_KNOWLEDGEBASE_DRIVE_EVENT_PREVIOUS_SIGNING_SECRET_FILE=/run/secrets/sdkwork/drive-event-signing/previous
SDKWORK_KNOWLEDGEBASE_DRIVE_EVENT_CHANNEL_TTL_SECONDS=86400
SDKWORK_KNOWLEDGEBASE_DRIVE_EVENT_CALLER_APP_ID=sdkwork-drive
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_EVENT_DELIVERY_RENEWAL_PAGE_SIZE=50
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_EVENT_DELIVERY_RENEWAL_INTERVAL_SECONDS=3600

SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=db.example.com
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_prod
SDKWORK_CLAW_DATABASE_PASSWORD_FILE=/run/secrets/sdkwork/database-password
SDKWORK_CLAW_DATABASE_SSL_MODE=require
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=32

SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=https://knowledgebase.sdkwork.com/app/v3/api
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=https://knowledgebase-admin.sdkwork.com/backend/v3/api
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=https://knowledge.sdkwork.com/knowledge/v3/api

SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com

SDKWORK_KNOWLEDGEBASE_DATABASE_MAX_CONNECTIONS=32
# Framework HTTP audit (fail-closed in production-like boot): apply
# database/migrations/postgres/0006_web_audit_event.up.sql and expose
# SDKWORK_KNOWLEDGEBASE_DATABASE_URL to all HTTP API processes.
SDKWORK_KNOWLEDGEBASE_DRIVE_STORAGE_ROOT=/var/lib/sdkwork/apps/sdkwork-knowledgebase/drive
SDKWORK_KNOWLEDGEBASE_SECRETS_ENCRYPTION_KEY_FILE=/run/secrets/sdkwork/secrets-encryption-key

# Commercial provider capabilities (enable only with deployed provider infrastructure)
# SDKWORK_KNOWLEDGEBASE_IMAGE_GENERATION_MODEL=openai/gpt-image-1
# SDKWORK_KNOWLEDGEBASE_TRANSCRIPTION_MODEL=openai/whisper-1

# Distributed rate limiting (multi-replica HA)
SDKWORK_KNOWLEDGEBASE_REDIS_ENABLED=true
SDKWORK_KNOWLEDGEBASE_REDIS_HOST=redis.example.com
SDKWORK_KNOWLEDGEBASE_REDIS_PORT=6379
SDKWORK_KNOWLEDGEBASE_REDIS_DATABASE=0
SDKWORK_KNOWLEDGEBASE_REDIS_TLS=true
SDKWORK_KNOWLEDGEBASE_REDIS_KEY_PREFIX=sdkwork:knowledgebase

# Outbox delivery is required outside development; configure it before cutover.
# SDKWORK_KNOWLEDGEBASE_OUTBOX_WEBHOOK_URL=https://hooks.example.com/knowledgebase/outbox
# SDKWORK_KNOWLEDGEBASE_OUTBOX_WEBHOOK_SECRET_FILE=/run/secrets/sdkwork/outbox-webhook-secret

# OpenTelemetry is optional when an OTLP collector is available.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com:4318
# OTEL_SERVICE_NAME=sdkwork-knowledgebase-public-ingress
SDKWORK_KNOWLEDGEBASE_LOG_FORMAT=json

# Snowflake nodes use fenced database leases. Kubernetes injects
# SDKWORK_NODE_INSTANCE_ID from metadata.uid; static node IDs are emergency-only.
# SDKWORK_KNOWLEDGEBASE_ORGANIZATION_ID=

VITE_SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=production
VITE_SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=prod
VITE_SDKWORK_KNOWLEDGEBASE_BUILD_MODE=production
VITE_SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=browser
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=https://knowledgebase.sdkwork.com/app/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=https://knowledgebase-admin.sdkwork.com/backend/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=https://knowledge.sdkwork.com/knowledge/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
