
SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=cloud
SDKWORK_DRIVE_DOMAIN_OUTBOX_EMBEDDED_DISPATCH=false
SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=development
SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=dev
SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=container
SDKWORK_KNOWLEDGEBASE_PROFILE_ID=cloud.development
SDKWORK_KNOWLEDGEBASE_DEV_ALLOWED_ORIGINS=http://127.0.0.1:5184,http://localhost:5184
# Must match sdkwork.app.config.json backend.tenantId and IAM login tenant.
SDKWORK_KNOWLEDGEBASE_TENANT_ID=100001
SDKWORK_KNOWLEDGEBASE_ORGANIZATION_ID=0
SDKWORK_KNOWLEDGEBASE_DRIVE_INTERNAL_API_BASE_URL=http://127.0.0.1:18080
# Development placeholder: inject a real ingress token file before starting cloud mode.
SDKWORK_KNOWLEDGEBASE_DRIVE_INTERNAL_API_INGRESS_TOKEN_FILE=./.sdkwork/runtime/secrets/drive-internal-api-token
SDKWORK_KNOWLEDGEBASE_DRIVE_EVENT_CALLBACK_URL=https://api-dev.sdkwork.com/internal/v3/api/knowledgebase/drive_events
SDKWORK_KNOWLEDGEBASE_DRIVE_EVENT_SIGNING_SECRET_FILE=./.sdkwork/runtime/secrets/drive-event-signing-master
# Optional during a controlled signing-secret rotation only.
# SDKWORK_KNOWLEDGEBASE_DRIVE_EVENT_PREVIOUS_SIGNING_SECRET_FILE=./.sdkwork/runtime/secrets/drive-event-signing-master.previous
SDKWORK_KNOWLEDGEBASE_DRIVE_EVENT_CHANNEL_TTL_SECONDS=86400
SDKWORK_KNOWLEDGEBASE_DRIVE_EVENT_CALLER_APP_ID=sdkwork-drive
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_ACTOR_ID=9001
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_CHECKPOINT_PAGE_SIZE=50
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_EVENT_BATCH_SIZE=25
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_EVENT_LEASE_SECONDS=120
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_EVENT_RETRY_DELAY_SECONDS=30
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_EVENT_MAX_ATTEMPTS=20
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_SOURCE_BATCH_SIZE=10
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_SOURCE_LEASE_SECONDS=120
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_SOURCE_RETRY_DELAY_SECONDS=30
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_SOURCE_MAX_ATTEMPTS=10
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_EVENT_DELIVERY_RENEWAL_PAGE_SIZE=50
SDKWORK_KNOWLEDGEBASE_WORKER_WIKI_EVENT_DELIVERY_RENEWAL_INTERVAL_SECONDS=3600

SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_dev
# Load from .env.postgres (copy from .env.postgres.example). Do not commit secrets here.
# SDKWORK_CLAW_DATABASE_PASSWORD=
SDKWORK_CLAW_DATABASE_SSL_MODE=disable
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=10

SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=https://api.sdkwork.com
SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=https://api-dev.sdkwork.com/backend/v3/api
SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=https://api-dev.sdkwork.com/knowledge/v3/api
SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com

VITE_SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_KNOWLEDGEBASE_ENVIRONMENT=development
VITE_SDKWORK_KNOWLEDGEBASE_CONFIG_PROFILE=dev
VITE_SDKWORK_KNOWLEDGEBASE_BUILD_MODE=development
VITE_SDKWORK_KNOWLEDGEBASE_RUNTIME_TARGET=browser
VITE_SDKWORK_KNOWLEDGEBASE_DEV_SAME_ORIGIN_API=true
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL=https://api.sdkwork.com
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL=https://api-dev.sdkwork.com/backend/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL=https://api-dev.sdkwork.com/knowledge/v3/api
VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
VITE_SDKWORK_APPBASE_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_SDKWORK_IAM_APP_API_BASE_URL=http://127.0.0.1:3900
