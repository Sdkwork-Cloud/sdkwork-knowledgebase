# SDKWork Knowledgebase Redis runtime profile (production / multi-replica HA)
#
# Enable distributed rate limiting for app-api, backend-api, and open-api routers.
# Standalone development can omit these keys and use in-memory rate limiting.

# Preferred: explicit Redis URL override
# SDKWORK_KNOWLEDGEBASE_REDIS_URL=redis://127.0.0.1:6379/0

# Structured Redis configuration (used when URL is not set)
SDKWORK_KNOWLEDGEBASE_REDIS_ENABLED=true
SDKWORK_KNOWLEDGEBASE_REDIS_HOST=127.0.0.1
SDKWORK_KNOWLEDGEBASE_REDIS_PORT=6379
SDKWORK_KNOWLEDGEBASE_REDIS_DATABASE=0
SDKWORK_KNOWLEDGEBASE_REDIS_TLS=false
SDKWORK_KNOWLEDGEBASE_REDIS_KEY_PREFIX=sdkwork:knowledgebase

# Optional credentials for ACL-enabled Redis deployments
# SDKWORK_KNOWLEDGEBASE_REDIS_USERNAME=
# SDKWORK_KNOWLEDGEBASE_REDIS_PASSWORD=
