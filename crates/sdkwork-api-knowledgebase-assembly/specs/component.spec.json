{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "sdkwork-api-knowledgebase-assembly",
    "displayName": "SDKWork Knowledgebase Gateway Assembly",
    "version": "0.1.0",
    "type": "rust-api-assembly",
    "root": "crates/sdkwork-api-knowledgebase-assembly",
    "domain": "intelligence",
    "capability": "api-assembly",
    "surface": "api-assembly",
    "status": "standard",
    "languages": [
      "rust"
    ],
    "generated": true,
    "private": false,
    "manifests": [
      "Cargo.toml",
      "assembly-manifest.json"
    ]
  },
  "contracts": {
    "publicExports": [
      "sdkwork_api_knowledgebase_assembly::assemble_api_router",
      "sdkwork_api_knowledgebase_assembly::assemble_api_router",
      "sdkwork_api_knowledgebase_assembly::ApiAssembly"
    ],
    "runtimeEntrypoints": [
      "sdkwork_api_knowledgebase_assembly::assemble_api_router"
    ],
    "dependencyApiSurfaces": [
      {
        "workspace": "sdkwork-iam",
        "sdkFamily": "sdkwork-iam-app-sdk",
        "apiAuthority": "sdkwork-iam-app-api",
        "surface": "app-api",
        "runtimeMode": "embedded",
        "sameOriginAllowed": true,
        "embeddedExecutableExport": "sdkwork_api_iam_assembly::assemble_api_router",
        "cargoDependency": "sdkwork_api_iam_assembly"
      }
    ],
    "layerRole": "runtime-composition"
  },
  "integration": {
    "dependencyPolicy": "Standalone assembly embeds IAM app-api business routes through sdkwork-api-iam-assembly; consumers must not depend on sdkwork-routes-iam-app-api directly.",
    "sdkPolicy": "Assembly output is materialized by gateway scripts and must not bypass dependency assembly exports."
  },
  "verification": {
    "commands": [
      "cargo check -p sdkwork-api-knowledgebase-standalone-gateway",
      "pnpm api:assembly:validate"
    ]
  }
}
