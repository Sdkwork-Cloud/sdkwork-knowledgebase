{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "sdkwork-knowledgebase-gateway-assembly",
    "displayName": "SDKWork Knowledgebase Gateway Assembly",
    "version": "0.1.0",
    "type": "gateway-assembly",
    "root": "sdkwork-knowledgebase/crates/sdkwork-knowledgebase-gateway-assembly",
    "domain": "intelligence",
    "capability": "knowledgebase",
    "surface": "gateway/assembly",
    "status": "standard",
    "languages": [
      "rust"
    ],
    "generated": true,
    "private": false,
    "manifests": [
      "Cargo.toml",
      "assembly-manifest.json"
    ]
  },
  "contracts": {
    "publicExports": [
      "sdkwork_knowledgebase_gateway_assembly::assemble_application_router",
      "sdkwork_knowledgebase_gateway_assembly::assemble_application_business_router",
      "sdkwork_knowledgebase_gateway_assembly::ApplicationAssembly"
    ],
    "runtimeEntrypoints": [
      "sdkwork_knowledgebase_gateway_assembly::assemble_application_router"
    ],
    "dependencyApiSurfaces": [
      {
        "workspace": "sdkwork-iam",
        "sdkFamily": "sdkwork-iam-app-sdk",
        "apiAuthority": "sdkwork-iam-app-api",
        "surface": "app-api",
        "runtimeMode": "embedded",
        "sameOriginAllowed": true,
        "embeddedExecutableExport": "sdkwork_iam_gateway_assembly::assemble_application_business_router",
        "cargoDependency": "sdkwork_iam_gateway_assembly"
      }
    ]
  },
  "integration": {
    "dependencyPolicy": "Standalone assembly embeds IAM app-api business routes through sdkwork-iam-gateway-assembly; consumers must not depend on sdkwork-routes-iam-app-api directly.",
    "sdkPolicy": "Assembly output is materialized by gateway scripts and must not bypass dependency assembly exports."
  },
  "verification": {
    "commands": [
      "cargo check -p sdkwork-knowledgebase-standalone-gateway",
      "pnpm api:assembly:validate"
    ]
  }
}
