# SDKWork Knowledgebase PC desktop host profile (development example)
#
# Copy to a local override file outside version control when customizing desktop host behavior.

[app]
key = "sdkwork-knowledgebase-pc"
runtime_target = "desktop"
deployment_mode = "desktop"

[window]
title = "SDKWork Knowledgebase"
width = 1440
height = 900

[runtime]
hosting = "self-hosted"
environment = "development"
