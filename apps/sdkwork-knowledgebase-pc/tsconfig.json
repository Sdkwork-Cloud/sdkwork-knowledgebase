{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@sdkwork/sdkwork-knowledgebase-pc-commons": [
        "./packages/sdkwork-knowledgebase-pc-commons/src/index.ts"
      ],
      "@sdkwork/sdkwork-knowledgebase-pc-commons/*": [
        "./packages/sdkwork-knowledgebase-pc-commons/src/*"
      ],
      "@sdkwork/sdkwork-knowledgebase-pc-knowledgebase": [
        "./packages/sdkwork-knowledgebase-pc-knowledgebase/src/index.ts"
      ],
      "@sdkwork/sdkwork-knowledgebase-pc-knowledgebase/*": [
        "./packages/sdkwork-knowledgebase-pc-knowledgebase/src/*"
      ],
      "@sdkwork/sdkwork-knowledgebase-pc-shell": [
        "./packages/sdkwork-knowledgebase-pc-shell/src/index.ts"
      ],
      "sdkwork-knowledgebase-pc-core": [
        "./packages/sdkwork-knowledgebase-pc-core/src"
      ],
      "sdkwork-knowledgebase-pc-core/config/runtimeConfig": [
        "./packages/sdkwork-knowledgebase-pc-core/src/config/runtimeConfig.ts"
      ],
      "sdkwork-knowledgebase-pc-core/session/sessionStore": [
        "./packages/sdkwork-knowledgebase-pc-core/src/session/sessionStore.ts"
      ],
      "sdkwork-knowledgebase-pc-core/host/hostAdapter": [
        "./packages/sdkwork-knowledgebase-pc-core/src/host/hostAdapter.ts"
      ],
      "react": [
        "./node_modules/@types/react/index.d.ts"
      ],
      "react-dom": [
        "./node_modules/@types/react-dom/index.d.ts"
      ],
      "react/jsx-runtime": [
        "./node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "./node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-router-dom": [
        "./node_modules/react-router-dom/dist/index.d.ts"
      ],
      "@sdkwork/appbase-pc-react": [
        "../../../sdkwork-appbase/packages/pc-react/foundation/sdkwork-appbase-pc-react/src/index.ts"
      ],
      "@sdkwork/auth-pc-react": [
        "./src/bootstrap/sdkworkAuthPcReactShim.d.ts"
      ],
      "@sdkwork/iam-app-sdk": [
        "../../../sdkwork-iam/sdks/sdkwork-iam-app-sdk/sdkwork-iam-app-sdk-typescript/generated/server-openapi/src/index.ts"
      ],
      "@sdkwork/auth-runtime-pc-react": [
        "../../../sdkwork-iam/apps/sdkwork-iam-pc/packages/sdkwork-auth-runtime-pc-react/src/index.ts"
      ],
      "@sdkwork/knowledgebase-app-sdk": [
        "../../sdks/sdkwork-knowledgebase-app-sdk/sdkwork-knowledgebase-app-sdk-typescript/src/index.ts"
      ],
      "@sdkwork/iam-backend-sdk": [
        "../../../sdkwork-iam/sdks/sdkwork-iam-backend-sdk/sdkwork-iam-backend-sdk-typescript/generated/server-openapi/src/index.ts"
      ],
      "@sdkwork/core-pc-react": [
        "./src/bootstrap/sdkworkCorePcReactShim.ts"
      ],
      "@sdkwork/iam-contracts": [
        "../../../sdkwork-iam/apps/sdkwork-iam-common/packages/sdkwork-iam-contracts/src/index.ts"
      ],
      "@sdkwork/sdk-common": [
        "../../../sdkwork-sdk-commons/sdkwork-sdk-common-typescript/src/index.ts"
      ],
      "@sdkwork/ui-pc-react": [
        "../../../sdkwork-ui/sdkwork-ui-pc-react/src/index.ts"
      ],
      "@sdkwork/knowledgebase-pc-search": [
        "./packages/sdkwork-knowledgebase-pc-search/src/index.ts"
      ],
      "@sdkwork/sdkwork-knowledgebase-pc-commons/reactKeyedProps": [
        "./packages/sdkwork-knowledgebase-pc-commons/src/reactKeyedProps.ts"
      ],
      "@sdkwork/sdkwork-knowledgebase-pc-commons/htmlSanitizer": [
        "./packages/sdkwork-knowledgebase-pc-commons/src/htmlSanitizer.ts"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src",
    "packages"
  ]
}
