{
  "schemaVersion": 2,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-knowledgebase",
  "archetype": "application-http-gateway",
  "profileRoot": "configs/topology",
  "profilePattern": "{deploymentProfile}.{serviceLayout}.{environment}.env",
  "vocabulary": {
    "deploymentProfile": { "allowed": ["standalone", "cloud"] },
    "serviceLayout": { "allowed": ["unified-process", "split-services"] },
    "environment": { "allowed": ["development", "production"] }
  },
  "defaults": {
    "developmentProfileId": "standalone.unified-process.development",
    "productionProfileId": "cloud.split-services.production",
    "desktopBuildProfileId": "standalone.unified-process.production",
    "gatewayBind": "127.0.0.1:3900"
  },
  "profileFiles": {
    "standalone.unified-process.development": "configs/topology/standalone.unified-process.development.env",
    "standalone.unified-process.production": "configs/topology/standalone.unified-process.production.env",
    "cloud.split-services.development": "configs/topology/cloud.split-services.development.env",
    "cloud.split-services.production": "configs/topology/cloud.split-services.production.env"
  },
  "envKeys": {
    "deploymentProfile": "SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE",
    "serviceLayout": "SDKWORK_KNOWLEDGEBASE_SERVICE_LAYOUT",
    "environment": "SDKWORK_KNOWLEDGEBASE_ENVIRONMENT",
    "profileId": "SDKWORK_KNOWLEDGEBASE_PROFILE_ID",
    "clientDeploymentProfile": "VITE_SDKWORK_KNOWLEDGEBASE_DEPLOYMENT_PROFILE",
    "gatewayAutostart": "SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_AUTOSTART",
    "standaloneGatewayBind": "SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_INGRESS_BIND",
    "cloudGatewayBind": "SDKWORK_API_GATEWAY_BIND",
    "cloudGatewayConfig": "SDKWORK_API_GATEWAY_CONFIG",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL",
    "apiGatewayBaseUrl": "SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": ["http"],
      "bindEnv": "SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_PUBLIC_HTTP_URL"
    },
    "application.backend-http": {
      "connectivityPlane": "application",
      "protocols": ["http"],
      "bindEnv": "SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_BIND",
      "httpUrlEnv": "SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_BACKEND_HTTP_URL"
    },
    "application.open-http": {
      "connectivityPlane": "application",
      "protocols": ["http"],
      "bindEnv": "SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_BIND",
      "httpUrlEnv": "SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_KNOWLEDGEBASE_APPLICATION_OPEN_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": ["http"],
      "owner": "sdkwork-api-gateway",
      "bindEnv": "SDKWORK_API_GATEWAY_BIND",
      "httpUrlEnv": "SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_HTTP_URL",
      "autostartEnv": "SDKWORK_KNOWLEDGEBASE_PLATFORM_API_GATEWAY_AUTOSTART"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": { "httpHost": "knowledgebase.sdkwork.com" },
    "application.backend-http": { "httpHost": "knowledgebase-admin.sdkwork.com" },
    "application.open-http": { "httpHost": "knowledge.sdkwork.com" },
    "platform.api-gateway": { "httpHost": "api.sdkwork.com" }
  },
  "database": {
    "appPrefix": "SDKWORK_KNOWLEDGEBASE"
  },
  "components": {
    "appApiRouter": {
      "crate": "sdkwork-knowledgebase-api-server",
      "binary": "sdkwork-knowledgebase-app-api"
    },
    "backendApiRouter": {
      "crate": "sdkwork-knowledgebase-api-server",
      "binary": "sdkwork-knowledgebase-backend-api"
    },
    "openApiRouter": {
      "crate": "sdkwork-knowledgebase-api-server",
      "binary": "sdkwork-knowledgebase-open-api"
    },
    "cloudGateway": {
      "crate": "sdkwork-api-gateway-api-server",
      "binary": "sdkwork-api-gateway",
      "repository": "sdkwork-api-gateway",
      "configGlob": "configs/sdkwork-api-gateway.knowledgebase.{profile}.toml"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.unified-process.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-knowledgebase-api-server",
            "binary": "sdkwork-knowledgebase-app-api",
            "required": true
          }
        ],
        "healthSurfaces": ["application.public-ingress"]
      },
      "cloud.split-services.development": {
        "processes": [
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-gateway-api-server",
            "binary": "sdkwork-api-gateway",
            "repository": "sdkwork-api-gateway",
            "required": false
          },
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-knowledgebase-api-server",
            "binary": "sdkwork-knowledgebase-app-api",
            "required": true
          },
          {
            "id": "application.backend-http",
            "crate": "sdkwork-knowledgebase-api-server",
            "binary": "sdkwork-knowledgebase-backend-api",
            "required": true
          },
          {
            "id": "application.open-http",
            "crate": "sdkwork-knowledgebase-api-server",
            "binary": "sdkwork-knowledgebase-open-api",
            "required": true
          }
        ],
        "healthSurfaces": [
          "platform.api-gateway",
          "application.public-ingress",
          "application.backend-http",
          "application.open-http"
        ]
      }
    }
  },
  "packaging": {
    "cloudConfigFiles": [
      "sdkwork-api-gateway.knowledgebase.development.toml",
      "sdkwork-api-gateway.knowledgebase.production.toml"
    ],
    "targets": [
      {
        "id": "container-noarch-cloud-container-config-bundle-tar-gz",
        "profile": "container",
        "platform": "container",
        "architecture": "noarch",
        "formats": ["tar.gz"],
        "runner": "ubuntu-24.04",
        "outputGlob": "dist/cloud-config/sdkwork-knowledgebase-api-gateway-config-*.tar.gz",
        "deploymentProfile": "cloud",
        "runtimeTarget": "container",
        "variant": "config-bundle"
      }
    ]
  },
  "scripts": {
    "dev": "scripts/knowledgebase-dev.mjs"
  },
  "retired": {
    "envKeys": [
      "SDKWORK_KNOWLEDGEBASE_APP_LISTEN",
      "SDKWORK_KNOWLEDGEBASE_BACKEND_LISTEN",
      "SDKWORK_KNOWLEDGEBASE_OPEN_LISTEN",
      "SDKWORK_KNOWLEDGEBASE_OPEN_API_BASE_URL"
    ]
  }
}
