  "components": {
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "KnowledgeRetrievalResult": {
        "type": "object",
        "required": [
          "retrievalId",
          "hits"
        ],
        "properties": {
          "retrievalId": {
            "type": "string",
            "pattern": "^[0-9]+$",
            "x-sdkwork-int64-string": true
          },
          "trace": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/KnowledgeRetrievalTrace"
              },
              {
                "type": "null"
              }
            ]
          },
          "hits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KnowledgeContextFragment"
            }
          }
        }
      },
      "KnowledgeRetrievalTrace": {
        "type": "object",
        "required": [
          "retrievalTraceId",
          "status",
          "resultCount"
        ],
        "properties": {
          "retrievalTraceId": {
            "type": "string",
            "pattern": "^[0-9]+$",
            "x-sdkwork-int64-string": true
          },
          "status": {
            "type": "string"
          },
          "latencyMs": {
            "anyOf": [
              {
                "type": "integer",
                "format": "uint64"
              },
              {
                "type": "null"
              }
            ]
          },
          "resultCount": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "KnowledgeContextFragment": {
        "type": "object",
        "required": [
          "chunkId",
          "documentId",
          "spaceId",
          "title",
          "content",
          "rank",
          "retrievalMethod"
        ],
        "properties": {
          "chunkId": {
            "type": "string",
            "pattern": "^[0-9]+$",
            "x-sdkwork-int64-string": true
          },
          "documentId": {
            "type": "string",
            "pattern": "^[0-9]+$",
            "x-sdkwork-int64-string": true
          },
          "documentVersionId": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[0-9]+$",
                "x-sdkwork-int64-string": true
              },
              {
                "type": "null"
              }
            ]
          },
          "spaceId": {
            "type": "string",
            "pattern": "^[0-9]+$",
            "x-sdkwork-int64-string": true
          },
          "collectionId": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[0-9]+$",
                "x-sdkwork-int64-string": true
              },
              {
                "type": "null"
              }
            ]
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "score": {
            "anyOf": [
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "null"
              }
            ]
          },
          "rank": {
            "type": "integer",
            "format": "int32"
          },
          "tokenCount": {
            "anyOf": [
              {
                "type": "integer",
                "format": "int32"
              },
              {
                "type": "null"
              }
            ]
          },
          "retrievalMethod": {
            "$ref": "#/components/schemas/KnowledgeRetrievalMethod"
          },
          "citation": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/KnowledgeCitation"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "KnowledgeRetrievalMethod": {
        "type": "string",
        "enum": [
          "exact",
          "keyword",
          "full_text",
          "structured",
          "graph",
          "vector",
          "hybrid",
          "llm_rerank",
          "external"
        ]
      },
      "KnowledgeCitation": {
        "type": "object",
        "required": [
          "documentId",
          "title"
        ],
        "properties": {
          "documentId": {
            "type": "string",
            "pattern": "^[0-9]+$",
            "x-sdkwork-int64-string": true
          },
          "documentVersionId": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[0-9]+$",
                "x-sdkwork-int64-string": true
              },
              {
                "type": "null"
              }
            ]
          },
          "chunkId": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[0-9]+$",
                "x-sdkwork-int64-string": true
              },
              {
                "type": "null"
              }
            ]
          },
          "title": {
            "type": "string"
          },
          "sourceUri": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "locator": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "score": {
            "anyOf": [
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "required": [
          "type",
          "title",
          "status"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "detail": {
            "type": [
              "string",
              "null"
            ]
          },
          "instance": {
            "type": [
              "string",
              "null"
            ]
          },
          "code": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "KnowledgeRetrievalRequest": {
        "type": "object",
        "required": [
          "query",
          "bindings",
          "includeCitations",
          "includeTrace"
        ],
        "properties": {
          "actorId": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[0-9]+$",
                "x-sdkwork-int64-string": true
              },
              {
                "type": "null"
              }
            ]
          },
          "query": {
            "type": "string"
          },
          "retrievalProfileId": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[0-9]+$",
                "x-sdkwork-int64-string": true
              },
              {
                "type": "null"
              }
            ]
          },
          "bindings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KnowledgeRetrievalBinding"
            }
          },
          "methods": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KnowledgeRetrievalMethod"
            },
            "default": []
          },
          "topK": {
            "anyOf": [
              {
                "type": "integer",
                "format": "int32"
              },
              {
                "type": "null"
              }
            ]
          },
          "includeCitations": {
            "type": "boolean"
          },
          "includeTrace": {
            "type": "boolean"
          },
          "contextBudgetTokens": {
            "anyOf": [
              {
                "type": "integer",
                "format": "int32"
              },
              {
                "type": "null"
              }
            ]
          },
          "metadata": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KnowledgeFilter"
            },
            "default": []
          }
