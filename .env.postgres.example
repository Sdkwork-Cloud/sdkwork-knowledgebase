# SDKWork Knowledgebase local PostgreSQL development template.
# Copy to .env.postgres for host-local overrides. Do not commit .env.postgres.
#
# `pnpm dev`, `pnpm dev:browser`, and `pnpm dev:desktop` use this PostgreSQL
# standalone profile by default for Knowledgebase metadata and embedded Drive schema.

SDKWORK_KNOWLEDGEBASE_DATABASE_ENGINE=postgresql
SDKWORK_KNOWLEDGEBASE_DATABASE_HOST=127.0.0.1
SDKWORK_KNOWLEDGEBASE_DATABASE_PORT=5432
SDKWORK_KNOWLEDGEBASE_DATABASE_NAME=sdkwork_knowledgebase_dev
SDKWORK_KNOWLEDGEBASE_DATABASE_SCHEMA=public
SDKWORK_KNOWLEDGEBASE_DATABASE_USERNAME=sdkworkdev
SDKWORK_KNOWLEDGEBASE_DATABASE_PASSWORD=sdkwork_dev_password
SDKWORK_KNOWLEDGEBASE_DATABASE_SSL_MODE=disable
SDKWORK_KNOWLEDGEBASE_DATABASE_MAX_CONNECTIONS=10
SDKWORK_KNOWLEDGEBASE_DATABASE_ADMIN_HOST=127.0.0.1
SDKWORK_KNOWLEDGEBASE_DATABASE_ADMIN_PORT=5432
SDKWORK_KNOWLEDGEBASE_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_KNOWLEDGEBASE_DATABASE_ADMIN_PASSWORD=postgres_admin_pass
SDKWORK_KNOWLEDGEBASE_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_KNOWLEDGEBASE_DATABASE_ADMIN_SSL_MODE=disable
# SDKWORK_KNOWLEDGEBASE_DATABASE_URL=postgresql://sdkworkdev:sdkwork_dev_password@127.0.0.1:5432/sdkwork_knowledgebase_dev?sslmode=disable
