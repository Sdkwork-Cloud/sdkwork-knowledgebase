{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sdkwork:knowledgebase:provider-load-slo-evidence:v1",
  "title": "SDKWork Knowledgebase Provider Load And SLO Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "status",
    "providerId",
    "upstreamVersion",
    "adapterCommit",
    "policyVersion",
    "verifiedAt",
    "expiresAt",
    "environment",
    "workflowRunRef",
    "reviewedBy",
    "dashboardRef",
    "alertEvaluationRef",
    "rawResultsRef",
    "rawResultsSha256",
    "aggregate",
    "operationMetrics"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "sdkwork.knowledge-engine-load-slo-evidence" },
    "status": { "const": "passed" },
    "providerId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
    "upstreamVersion": { "type": "string", "minLength": 1, "not": { "pattern": "latest|[*xX]" } },
    "adapterCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "policyVersion": { "const": "1.0.0" },
    "verifiedAt": { "type": "string", "format": "date" },
    "expiresAt": { "type": "string", "format": "date" },
    "environment": { "const": "release" },
    "workflowRunRef": { "type": "string", "pattern": "^https://" },
    "reviewedBy": { "type": "string", "minLength": 1 },
    "dashboardRef": { "type": "string", "pattern": "^https://" },
    "alertEvaluationRef": { "type": "string", "pattern": "^https://" },
    "rawResultsRef": { "$ref": "#/$defs/artifactRef" },
    "rawResultsSha256": { "$ref": "#/$defs/sha256" },
    "aggregate": { "$ref": "#/$defs/aggregate" },
    "operationMetrics": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/operationMetric" }
    }
  },
  "$defs": {
    "artifactRef": {
      "type": "string",
      "pattern": "^docs/releases/provider-certification/artifacts/[^.][^\\r\\n]*$"
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "durationSeconds",
        "totalRequests",
        "concurrency",
        "successCount",
        "failureCount",
        "availability",
        "failureRate",
        "p95LatencyMs",
        "p99LatencyMs",
        "throughputPerSecond",
        "tenantCount",
        "crossTenantViolationCount"
      ],
      "properties": {
        "durationSeconds": { "type": "number", "minimum": 0 },
        "totalRequests": { "type": "integer", "minimum": 0 },
        "concurrency": { "type": "integer", "minimum": 1 },
        "successCount": { "type": "integer", "minimum": 0 },
        "failureCount": { "type": "integer", "minimum": 0 },
        "availability": { "type": "number", "minimum": 0, "maximum": 1 },
        "failureRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "p95LatencyMs": { "type": "number", "minimum": 0 },
        "p99LatencyMs": { "type": "number", "minimum": 0 },
        "throughputPerSecond": { "type": "number", "minimum": 0 },
        "tenantCount": { "type": "integer", "minimum": 0 },
        "crossTenantViolationCount": { "type": "integer", "minimum": 0 }
      }
    },
    "operationMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "requestCount",
        "successCount",
        "failureCount",
        "availability",
        "failureRate",
        "p95LatencyMs",
        "p99LatencyMs",
        "throughputPerSecond",
        "concurrency"
      ],
      "properties": {
        "operation": { "enum": ["search", "read_document", "health"] },
        "requestCount": { "type": "integer", "minimum": 0 },
        "successCount": { "type": "integer", "minimum": 0 },
        "failureCount": { "type": "integer", "minimum": 0 },
        "availability": { "type": "number", "minimum": 0, "maximum": 1 },
        "failureRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "p95LatencyMs": { "type": "number", "minimum": 0 },
        "p99LatencyMs": { "type": "number", "minimum": 0 },
        "throughputPerSecond": { "type": "number", "minimum": 0 },
        "concurrency": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
