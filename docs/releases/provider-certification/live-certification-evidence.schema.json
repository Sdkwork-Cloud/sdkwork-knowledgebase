{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sdkwork:knowledgebase:provider-live-certification-evidence:v1",
  "title": "SDKWork Knowledgebase Provider Live Certification Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "status",
    "providerId",
    "upstreamVersion",
    "adapterCommit",
    "contractSuiteVersion",
    "verifiedAt",
    "expiresAt",
    "environment",
    "workflowRunRef",
    "reviewedBy",
    "qualityEvaluationRef",
    "qualityEvaluationSha256",
    "contractReportRef",
    "contractReportSha256",
    "loadSloRef",
    "loadSloSha256",
    "outageRecoveryRef",
    "outageRecoverySha256",
    "licensingReviewRef",
    "licensingReviewSha256",
    "licensingApproval",
    "securityPrivacyReviewRef",
    "securityPrivacyReviewSha256",
    "securityPrivacyApproval"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "sdkwork.knowledge-engine-live-certification-evidence" },
    "status": { "const": "certified" },
    "providerId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
    "upstreamVersion": { "type": "string", "minLength": 1, "not": { "pattern": "latest|[*xX]" } },
    "adapterCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "contractSuiteVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "verifiedAt": { "type": "string", "format": "date" },
    "expiresAt": { "type": "string", "format": "date" },
    "environment": { "const": "release" },
    "workflowRunRef": { "type": "string", "pattern": "^https://" },
    "reviewedBy": { "type": "string", "minLength": 1 },
    "qualityEvaluationRef": { "$ref": "#/$defs/artifactRef" },
    "qualityEvaluationSha256": { "$ref": "#/$defs/sha256" },
    "contractReportRef": { "$ref": "#/$defs/artifactRef" },
    "contractReportSha256": { "$ref": "#/$defs/sha256" },
    "loadSloRef": { "$ref": "#/$defs/artifactRef" },
    "loadSloSha256": { "$ref": "#/$defs/sha256" },
    "outageRecoveryRef": { "$ref": "#/$defs/artifactRef" },
    "outageRecoverySha256": { "$ref": "#/$defs/sha256" },
    "licensingReviewRef": { "$ref": "#/$defs/artifactRef" },
    "licensingReviewSha256": { "$ref": "#/$defs/sha256" },
    "licensingApproval": { "const": "approved" },
    "securityPrivacyReviewRef": { "$ref": "#/$defs/artifactRef" },
    "securityPrivacyReviewSha256": { "$ref": "#/$defs/sha256" },
    "securityPrivacyApproval": { "const": "approved" }
  },
  "$defs": {
    "artifactRef": {
      "type": "string",
      "pattern": "^docs/releases/provider-certification/artifacts/[^.][^\\r\\n]*$"
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
