{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:sdkwork:knowledgebase:provider-quality-evaluation-evidence:v1",
  "title": "SDKWork Knowledgebase Provider Quality Evaluation Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "status",
    "providerId",
    "upstreamVersion",
    "adapterCommit",
    "datasetId",
    "datasetVersion",
    "datasetClassification",
    "datasetRef",
    "datasetSha256",
    "resultsRef",
    "resultsSha256",
    "evaluationReportRef",
    "evaluationReportSha256",
    "environment",
    "workflowRunRef",
    "verifiedAt",
    "expiresAt",
    "reviewedBy",
    "metrics"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "sdkwork.knowledge-engine-quality-evaluation-evidence" },
    "status": { "const": "passed" },
    "providerId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
    "upstreamVersion": { "type": "string", "minLength": 1, "not": { "pattern": "latest|[*xX]" } },
    "adapterCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "datasetId": { "type": "string", "minLength": 1 },
    "datasetVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "datasetClassification": { "const": "production-domain" },
    "datasetRef": { "$ref": "#/$defs/artifactRef" },
    "datasetSha256": { "$ref": "#/$defs/sha256" },
    "resultsRef": { "$ref": "#/$defs/artifactRef" },
    "resultsSha256": { "$ref": "#/$defs/sha256" },
    "evaluationReportRef": { "$ref": "#/$defs/artifactRef" },
    "evaluationReportSha256": { "$ref": "#/$defs/sha256" },
    "environment": { "const": "release" },
    "workflowRunRef": { "type": "string", "pattern": "^https://" },
    "verifiedAt": { "type": "string", "format": "date" },
    "expiresAt": { "type": "string", "format": "date" },
    "reviewedBy": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recallAtK",
        "mrr",
        "ndcgAtK",
        "citationCorrectness",
        "failureRate",
        "p95LatencyMs",
        "emptyQueryPassRate",
        "scoredQueryCount"
      ],
      "properties": {
        "recallAtK": { "type": "number", "minimum": 0, "maximum": 1 },
        "mrr": { "type": "number", "minimum": 0, "maximum": 1 },
        "ndcgAtK": { "type": "number", "minimum": 0, "maximum": 1 },
        "citationCorrectness": { "type": "number", "minimum": 0, "maximum": 1 },
        "failureRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "p95LatencyMs": { "type": "number", "minimum": 0 },
        "emptyQueryPassRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "scoredQueryCount": { "type": "integer", "minimum": 50, "maximum": 5000 }
      }
    }
  },
  "$defs": {
    "artifactRef": {
      "type": "string",
      "pattern": "^docs/releases/provider-certification/artifacts/[^.][^\\r\\n]*$"
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
