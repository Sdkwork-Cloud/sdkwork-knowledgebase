	path = external/knowledge-engines/upstream/anythingllm
	url = https://github.com/Mintplex-Labs/anything-llm.git

[submodule "external/knowledge-engines/upstream/open-webui"]
	path = external/knowledge-engines/upstream/open-webui
	url = https://github.com/open-webui/open-webui.git

[submodule "external/knowledge-engines/upstream/flowise"]
	path = external/knowledge-engines/upstream/flowise
	url = https://github.com/FlowiseAI/Flowise.git

[submodule "external/knowledge-engines/upstream/langchain"]
