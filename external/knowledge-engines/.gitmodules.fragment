# Reference fragment for optional upstream git submodule pins.
# Copy entries into .gitmodules when initializing adapter development:
#   node tools/sync_external_knowledge_engine_submodules.mjs --apply
#
# Catalog authority: external/knowledge-engines/catalog.manifest.json

[submodule "external/knowledge-engines/upstream/dify"]
	path = external/knowledge-engines/upstream/dify
	url = https://github.com/langgenius/dify.git

[submodule "external/knowledge-engines/upstream/ragflow"]
	path = external/knowledge-engines/upstream/ragflow
	url = https://github.com/infiniflow/ragflow.git

