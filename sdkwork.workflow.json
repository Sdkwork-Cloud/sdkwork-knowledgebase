{
  "$schema": "../sdkwork-github-workflow/schemas/sdkwork-workflow.schema.json",
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-knowledgebase",
    "name": "SDKWork Knowledgebase",
    "repository": "Sdkwork-Cloud/sdkwork-knowledgebase",
    "sourcePath": ".",
    "configPath": "sdkwork.app.config.json"
  },
  "release": {
    "artifactPrefix": "sdkwork-knowledgebase",
    "defaultVersion": "0.1.0",
    "changelog": {
      "source": "app-manifest",
      "maxCommitSubjects": 50
    }
  },
  "dependencies": [
    {
      "id": "sdkwork-appbase",
      "repository": "Sdkwork-Cloud/sdkwork-appbase",
      "refInput": "SDKWORK_APPBASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-web-framework",
      "repository": "Sdkwork-Cloud/sdkwork-web-framework",
      "refInput": "SDKWORK_WEB_FRAMEWORK_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-database",
      "repository": "Sdkwork-Cloud/sdkwork-database",
      "refInput": "SDKWORK_DATABASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-id",
      "repository": "Sdkwork-Cloud/sdkwork-id",
      "refInput": "SDKWORK_ID_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-generator",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-generator",
      "refInput": "SDKWORK_SDK_GENERATOR_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-app-topology",
      "repository": "Sdkwork-Cloud/sdkwork-app-topology",
      "refInput": "SDKWORK_APP_TOPOLOGY_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-drive",
      "repository": "Sdkwork-Cloud/sdkwork-drive",
      "refInput": "SDKWORK_DRIVE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-kernel",
      "repository": "Sdkwork-Cloud/sdkwork-kernel",
      "refInput": "SDKWORK_KERNEL_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-memory",
      "repository": "Sdkwork-Cloud/sdkwork-memory",
      "refInput": "SDKWORK_MEMORY_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-claw-router",
      "repository": "Sdkwork-Cloud/sdkwork-claw-router",
      "refInput": "SDKWORK_CLAW_ROUTER_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    }
  ],
  "toolchains": {
    "node": "22",
    "pnpm": "10.30.2",
    "rust": "stable"
  },
  "lifecycle": {
    "install": [
      {
        "name": "Install workspace dependencies",
        "shell": "pwsh",
        "run": "pnpm install --no-frozen-lockfile --config.auto-install-peers=false"
      }
    ],
    "build": [
      {
        "name": "Run SDKWork Knowledgebase Phase 1 verification",
        "shell": "pwsh",
        "run": "powershell -ExecutionPolicy Bypass -File tools/verify_phase1.ps1"
      },
      {
        "name": "Run architecture alignment check",
        "shell": "pwsh",
        "run": "node tools/check_sdkwork_knowledgebase_architecture_alignment.mjs"
      }
    ],
    "package": [
      {
        "name": "Build Knowledgebase API server binaries",
        "shell": "pwsh",
        "run": "cargo build --release -p sdkwork-knowledgebase-api-server"
      },
      {
        "name": "Build Knowledgebase PC web bundle",
        "shell": "pwsh",
        "run": "pnpm build"
      }
    ],
    "validate": [
      {
        "name": "Validate Knowledgebase contracts and architecture",
        "shell": "pwsh",
        "run": "pnpm verify"
      }
    ],
    "sign": [
      {
        "name": "Sign artifacts placeholder",
        "shell": "pwsh",
        "run": "Write-Host \"Signing policy is configured by release environment for $env:SDKWORK_PACKAGE_ID\""
      }
    ],
    "sbom": [
      {
        "name": "SBOM placeholder",
        "shell": "pwsh",
        "run": "Write-Host \"SBOM generation deferred until release gate enables supply-chain evidence\""
      }
    ]
  },
  "targets": [
    {
      "id": "linux-x64-standalone-server-tar-gz",
      "profile": "server",
      "platform": "linux",
      "architecture": "x64",
      "formats": ["tar.gz"],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "target/release/sdkwork-knowledgebase-app-api*",
        "target/release/sdkwork-knowledgebase-backend-api*",
        "target/release/sdkwork-knowledgebase-open-api*"
      ],
      "deploymentProfile": "standalone",
      "runtimeTarget": "server"
    },
    {
      "id": "web-universal-cloud-browser-zip",
      "profile": "browser",
      "platform": "web",
      "architecture": "universal",
      "formats": ["zip"],
      "runner": "ubuntu-24.04",
      "outputGlobs": ["apps/sdkwork-knowledgebase-pc/dist/**"],
      "deploymentProfile": "cloud",
      "runtimeTarget": "browser"
    }
  ],
  "security": {
    "artifactAttestations": false,
    "sbomRequired": false,
    "signingRequired": false
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": false,
    "retentionDays": 30
  }
}
